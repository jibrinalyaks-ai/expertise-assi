generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  role          Role           @default(STUDENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  student       Student?
  teacher       Teacher?
  announcements Announcement[]
}

model Student {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNo       String       @unique
  class        String
  parentEmail  String?
  parentPhone  String?
  address      String?
  profilePic   String?
  dob          String?
  bloodGroup   String?
  genotype     String?
  bioFilled    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  attendance   Attendance[]
  grades       Grade[]
  subjects     SubjectRegistration[]
}

model Teacher {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String
  classAssigned String?
  profilePic    String?
  phone         String?
  address       String?
  bioFilled     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  classes       Class[]
  missingReports MissingReport[]
}

model Class {
  id        String   @id @default(cuid())
  name      String   @unique
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  present   Boolean
  class     String
  createdAt DateTime @default(now())
}

model Grade {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    String
  ca1        Float?   @default(0)
  ca2        Float?   @default(0)
  exam       Float?   @default(0)
  term       String
  attendance Int?     @default(100)
  createdAt  DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  target    String   @default("all")
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admission {
  id            String   @id @default(cuid())
  childName     String
  dob           String?
  gender        String?
  classFor      String
  parentName    String
  phone         String
  email         String
  address       String?
  visitDate     String?
  notes         String?
  status        String   @default("pending")
  paymentRef    String?
  paymentStatus String   @default("pending")
  ref           String   @unique
  applicantEmail String
  createdAt     DateTime @default(now())
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  eventDate   DateTime
  term        String
  year        String
  createdAt   DateTime @default(now())
}

model SubjectRegistration {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjects  String[]
  createdAt DateTime @default(now())
}

model ResultRelease {
  id        String   @id @default(cuid())
  class     String
  term      String
  released  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MissingReport {
  id             String   @id @default(cuid())
  studentName    String
  studentClass   String
  teacherMessage String?
  teacherId      String
  teacher        Teacher  @relation(fields: [teacherId], references: [id])
  status         String   @default("pending")
  createdAt      DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}
